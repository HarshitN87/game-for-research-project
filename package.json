{
  "name": "signal-run-three-fps-study",
  "version": "0.9.0",
  "description": "Three.js FPS Demo",
  "keywords": [
    "webgl",
    "boilerplate",
    "three.js",
    "es6",
    "webpack"
  ],
  "scripts": {
    "start": "node --openssl-legacy-provider ./node_modules/webpack-cli/bin/cli.js serve",
    "prebuild": "node -e \"const fs=require('fs');fs.rmSync('./build',{recursive:true,force:true});fs.mkdirSync('./build',{recursive:true})\"",
    "build": "node --openssl-legacy-provider ./node_modules/webpack/bin/webpack.js --mode production"
  },
  "dependencies": {
    "@types/ammo.js": "github:osman-turan/ammo.js-typings",
    "ammo.js": "kripken/ammo.js",
    "three": "^0.127.0",
    "three-pathfinding": "^0.14.1",
    "webpack-cli": "^4.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.10",
    "@babel/preset-env": "^7.12.11",
    "babel-loader": "^8.2.2",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^4.5.1",
    "raw-loader": "^4.0.2",
    "webpack": "^5.14.0",
    "webpack-dev-server": "^4.15.2"
  },
  "engines": {
    "node": ">=8.0.0"
  },
  "browserslist": [
    "since 2017-06"
  ]
}
